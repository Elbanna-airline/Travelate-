// ---------- Click-to-fly: clicking a ticket flies the map to that city ----------
const cityMarkers = {}; // key: mapKey|lat|lng -> marker
function markerKey(mapKey,lat,lng){ return `${mapKey}|${lat}|${lng}`; }

function findRegionAndCountry(mapKey){
  for(const region of REGIONS){
    for(let idx=0; idx<region.countries.length; idx++){
      if(countryKey(region.id, idx) === mapKey){
        return { region, country:region.countries[idx], idx };
      }
    }
  }
  return null;
}

regionsWrap.addEventListener('click', (e)=>{
  const ticket = e.target.closest('.ticket');
  if(!ticket) return;
  const mapKey = ticket.dataset.mapkey;
  const lat = parseFloat(ticket.dataset.lat);
  const lng = parseFloat(ticket.dataset.lng);
  const found = findRegionAndCountry(mapKey);
  if(!found) return;
  initCountryMap(found.region, found.country, found.idx); // make sure the map exists
  flyToCity(mapKey, lat, lng);
});

function flyToCity(mapKey, lat, lng){
  const map = countryMapInstances[mapKey];
  if(!map) return;
  const mapEl = document.getElementById(`map-${mapKey}`);
  if(mapEl) mapEl.scrollIntoView({ behavior:'smooth', block:'center' });
  // keep a wider, more "zoomed out" view instead of getting too close to the pin
  const flyZoom = Math.min(Math.max(map.getZoom(), 7), 9);
  setTimeout(()=>{
    map.flyTo([lat,lng], flyZoom, { duration:0.9 });
    const key = markerKey(mapKey, lat, lng);
    const entry = cityMarkers[key];
    if(entry) setTimeout(()=> entry.openPopup(), 500);
  }, 250);
}

