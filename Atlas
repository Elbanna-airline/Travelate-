  /* ---------- HOTELS BUTTON ---------- */
  .ticket .hotels-btn{
    display:inline-flex; align-items:center; gap:5px;
    font-size:12px; font-weight:600;
    border:1.5px solid var(--accent,var(--primary));
    color:var(--accent,var(--primary));
    background:var(--surface);
    padding:6px 12px; border-radius:999px;
    cursor:pointer; white-space:nowrap;
    transition:background .3s cubic-bezier(0.4,0,0.2,1), color .3s cubic-bezier(0.4,0,0.2,1), transform .3s cubic-bezier(0.4,0,0.2,1);
  }
  .ticket .hotels-btn:hover{ background:var(--accent,var(--primary)); color:#fff; transform:translateY(-1px); }

  /* ---------- HOTELS MODAL ---------- */
  #hotels-overlay{
    position:fixed; inset:0; background:rgba(15,23,42,0);
    z-index:960; display:none; align-items:flex-end; justify-content:center;
    backdrop-filter:blur(0px); -webkit-backdrop-filter:blur(0px);
    transition:background .35s cubic-bezier(0.4,0,0.2,1), backdrop-filter .35s cubic-bezier(0.4,0,0.2,1);
  }
  #hotels-overlay.show{
    display:flex;
    background:rgba(15,23,42,.45);
    backdrop-filter:blur(6px); -webkit-backdrop-filter:blur(6px);
  }
  #hotels-modal{
    background:var(--surface); color:var(--ink);
    width:100%; max-width:720px; max-height:85vh; overflow-y:auto;
    border-radius:24px 24px 0 0; padding:28px 28px 36px;
    border:1px solid var(--border);
    box-shadow:var(--shadow-lg);
    opacity:0; transform:translateY(40px) scale(.98);
    transition:opacity .38s cubic-bezier(0.16,1,0.3,1), transform .38s cubic-bezier(0.16,1,0.3,1);
  }
  #hotels-overlay.show #hotels-modal{
    opacity:1; transform:translateY(0) scale(1);
  }
  @media (min-width:820px){
    #hotels-overlay{ align-items:center; }
    #hotels-modal{ border-radius:24px; max-height:82vh; }
  }
  #hotels-modal h3{ margin:0 0 6px; font-size:22px; color:var(--ink); }
  #hotels-modal .hotels-sub{ color:var(--muted); font-size:13.5px; margin:0 0 22px; line-height:1.6; }
  #hotels-close{
    position:sticky; float:left; top:0; background:none; border:none;
    color:var(--muted); font-size:22px; cursor:pointer; line-height:1;
  }
  #hotels-list{ display:flex; flex-direction:column; gap:10px; margin-bottom:8px; }
  .hotel-item{
    display:flex; flex-direction:column; gap:6px;
    background:var(--bg-2); border-radius:14px; padding:14px 18px;
    border:1px solid var(--border);
    transition:transform .2s ease, box-shadow .2s ease;
  }
  .hotel-item:hover{ transform:translateY(-1px); box-shadow:var(--shadow-sm); }
  .hotel-item .hotel-name{ font-weight:700; font-size:14.5px; color:var(--ink); }
  .hotel-item .hotel-desc{ font-size:12.8px; color:var(--ink-3); line-height:1.6; }
  .hotel-item .hotel-price-tag{
    display:inline-flex; align-items:center; gap:4px;
    font-size:11px; font-weight:600; color:var(--primary);
    background:rgba(15,110,99,.08); padding:3px 10px; border-radius:999px;
    width:fit-content; margin-top:2px;
  }
  .hotels-empty{ color:var(--muted); font-size:14px; text-align:center; padding:24px 0; line-height:1.6; }
  .hotels-city-header{
    display:flex; align-items:center; gap:10px;
    margin-bottom:18px; padding-bottom:14px;
    border-bottom:2px solid var(--border);
  }
  .hotels-city-header .city-flag{ font-size:28px; }
  .hotels-city-header .city-info{ flex:1; }
  .hotels-city-header .city-name{ font-weight:800; font-size:18px; color:var(--ink); }
  .hotels-city-header .city-count{ font-size:12px; color:var(--muted); }

