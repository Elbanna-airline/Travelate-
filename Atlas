}
function gmapDirUrl(lat1,lng1,lat2,lng2,mode){
  return `https://www.google.com/maps/dir/?api=1&origin=${lat1},${lng1}&destination=${lat2},${lng2}&travelmode=${mode}`;
}
function rome2rioUrl(fromEn,toEn){
  return `https://www.rome2rio.com/s/${encodeURIComponent(fromEn)}/${encodeURIComponent(toEn)}`;
}
// Haversine great-circle distance in km
function haversineKm(lat1,lng1,lat2,lng2){
  const R = 6371;
  const dLat = (lat2-lat1) * Math.PI/180;
  const dLng = (lng2-lng1) * Math.PI/180;
  const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLng/2)**2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}

