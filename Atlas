let tripCities = []; // {name,en,flag,country,lat,lng}

function toggleTicketDetails(btn){
  const ticket = btn.closest('.ticket');
  if(ticket) ticket.classList.toggle('expanded');
}

function toggleTripCity(btn){
  const ticket = btn.closest('.ticket');
  const d = ticket.dataset;
  const lat = parseFloat(d.lat), lng = parseFloat(d.lng);
  const idx = tripCities.findIndex(c=> c.lat===lat && c.lng===lng);
  if(idx > -1){
    tripCities.splice(idx,1);
    ticket.classList.remove('in-trip');
    btn.textContent = '➕ أضف للمخطط';
    closeNearestSuggestion();
  } else {
    const newCity = { name:d.name, en:d.en, flag:d.flag, country:d.country, lat, lng };
    tripCities.push(newCity);
    ticket.classList.add('in-trip');
    btn.textContent = '✅ في المخطط';
    showNearestSuggestion(newCity);
  }
  updateTripFab();
  renderTripList();
  updateTripRouteLine();
}

function updateTripFab(){
  const fab = document.getElementById('trip-fab');
  document.getElementById('trip-fab-count').textContent = tripCities.length;
  fab.classList.toggle('show', tripCities.length > 0);
}

function openTripModal(){
  renderTripList();
  const overlay = document.getElementById('trip-overlay');
  overlay.style.display = 'flex';
  // force a reflow so the browser registers the starting state before we add .show,
  // otherwise the transition would just snap straight to the end state
  void overlay.offsetWidth;
  overlay.classList.add('show');
}
function closeTripModal(){
  const overlay = document.getElementById('trip-overlay');
  overlay.classList.remove('show');
  const onEnd = (e)=>{
    if(e.target !== overlay) return;
    overlay.style.display = 'none';
    overlay.removeEventListener('transitionend', onEnd);
  };
  overlay.addEventListener('transitionend', onEnd);
}

function renderTripList(){
  const list = document.getElementById('trip-list');
  const calcBtn = document.getElementById('trip-calc-btn');
  const showRouteBtn = document.getElementById('trip-show-route-btn');
  if(tripCities.length === 0){
    list.innerHTML = `<p class="trip-empty">لسه مفيش مدن مختارة. اقفل النافذة واضغط "➕ أضف للمخطط" تحت أي مدينة عشان تبدأ.</p>`;
    calcBtn.disabled = true;
    showRouteBtn.disabled = true;
    document.getElementById('trip-results').innerHTML = '';
    return;
  }
  calcBtn.disabled = tripCities.length < 2;
  showRouteBtn.disabled = false;
  list.innerHTML = tripCities.map((c,i)=>`
    <div class="trip-item">
      <span class="order mono">${i+1}</span>
      <span class="flag">${c.flag}</span>
      <div class="info">
        <div class="city">${c.name}</div>
        <div class="country">${c.country}</div>
      </div>
      <div class="move-btns">
        <button class="icon-btn" title="تحريك لأعلى" onclick="moveTripCity(${i},-1)" ${i===0?'disabled':''}>▲</button>
        <button class="icon-btn" title="تحريك لأسفل" onclick="moveTripCity(${i},1)" ${i===tripCities.length-1?'disabled':''}>▼</button>
        <button class="icon-btn remove-btn" title="حذف" onclick="removeTripCity(${i})">✕</button>
      </div>
    </div>
  `).join('');
}

function moveTripCity(i, dir){
  const j = i + dir;
  if(j < 0 || j >= tripCities.length) return;
  [tripCities[i], tripCities[j]] = [tripCities[j], tripCities[i]];
  renderTripList();
  updateTripRouteLine();
}

function removeTripCity(i){
  const c = tripCities[i];
  tripCities.splice(i,1);
  // unmark the ticket in the grid if present
  document.querySelectorAll('.ticket.in-trip').forEach(t=>{
    if(parseFloat(t.dataset.lat)===c.lat && parseFloat(t.dataset.lng)===c.lng){
      t.classList.remove('in-trip');
      t.querySelector('.add-trip-btn').textContent = '➕ أضف للمخطط';
    }
  });
  updateTripFab();
  renderTripList();
  updateTripRouteLine();
  document.getElementById('trip-results').innerHTML = '';
}

function calculateTrip(){
  const results = document.getElementById('trip-results');
  if(tripCities.length < 2){ results.innerHTML = ''; return; }
  let totalKm = 0;
  const legsHtml = [];
  for(let i=0; i<tripCities.length-1; i++){
    const a = tripCities[i], b = tripCities[i+1];
    const km = haversineKm(a.lat,a.lng,b.lat,b.lng);
    totalKm += km;
    legsHtml.push(`
      <div class="leg-card">
        <div class="leg-route">${a.flag} ${a.name} <span class="arrow">→</span> ${b.flag} ${b.name}</div>
        <div class="leg-dist">مسافة جوية (خط مستقيم): ${Math.round(km).toLocaleString('en-US')} كم — الطريق الفعلي بالسيارة أطول عادةً</div>
        <div class="leg-actions">
          <a class="leg-btn car" href="${gmapDirUrl(a.lat,a.lng,b.lat,b.lng,'driving')}" target="_blank" rel="noopener">🚗 مسافة ووقت السيارة (خرائط جوجل)</a>
          <a class="leg-btn compare" href="${rome2rioUrl(a.en,b.en)}" target="_blank" rel="noopener">🚆 قارن قطار / سيارة / طيران (Rome2Rio)</a>
        </div>
      </div>
    `);
  }
  results.innerHTML = legsHtml.join('') +
    `<div class="trip-total">إجمالي المسافة الجوية التقريبية بين كل المحطات: <b>${Math.round(totalKm).toLocaleString('en-US')} كم</b></div>` +
    `<div class="trip-note">📌 المسافة الجوية محسوبة رياضيًا (خط مستقيم بين النقطتين) وهي دقيقة جغرافيًا، لكنها لا تساوي مسافة الطريق الفعلي. للحصول على مسافة ووقت السيارة الحقيقيين، أو لمعرفة توفر القطارات ومواعيدها وأسعارها التقريبية، اضغط الأزرار اللي جنب كل محطة — بتفتحلك بيانات حية ومحدثة من خرائط جوجل و Rome2Rio.</div>`;
}

