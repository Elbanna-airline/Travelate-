// ---------- Trip route line on the overview map (bold red line, like Google's route line) ----------
// NOTE: this function only *builds* the route layer — it does NOT touch the map's
// view or add the layer to the map. The map only updates when the person explicitly
// asks for it via revealTripRoute(), so picking cities never yanks the page around.
let tripRouteLine = null;
function updateTripRouteLine(){
  if(tripRouteLine){ overviewMap.removeLayer(tripRouteLine); tripRouteLine = null; }
  if(tripCities.length < 1) return;

  const layers = [];
  if(tripCities.length >= 2){
    const latlngs = tripCities.map(c=>[c.lat, c.lng]);
    // white halo underneath for contrast against any tile color, then a bold solid red line on top
    layers.push(L.polyline(latlngs, { color:'#ffffff', weight:7, opacity:.9, lineCap:'round', lineJoin:'round' }));
    layers.push(L.polyline(latlngs, { color:'#E63946', weight:4, opacity:1, lineCap:'round', lineJoin:'round' }));
    // small red dot at every stop, like a route endpoint marker
    tripCities.forEach(c=>{
      layers.push(L.circleMarker([c.lat,c.lng], { radius:6, weight:2, color:'#fff', fillColor:'#E63946', fillOpacity:1 }));
      // city name label sitting right above its dot, so every stop is clearly identified
      layers.push(L.marker([c.lat, c.lng], {
        icon: L.divIcon({
          className:'route-city-name-icon',
          html:`<div class="route-city-name-label">📍 ${c.name}</div>`,
          iconSize:[0,0]
        }),
        interactive:false, zIndexOffset:550
      }));
    });
    // km label sitting right on top of the red line, at the midpoint of each leg
    let totalKm = 0;
    for(let i=0; i<tripCities.length-1; i++){
      const a = tripCities[i], b = tripCities[i+1];
      const km = haversineKm(a.lat, a.lng, b.lat, b.lng);
      totalKm += km;
      const midLat = (a.lat + b.lat) / 2;
      const midLng = (a.lng + b.lng) / 2;
      layers.push(L.marker([midLat, midLng], {
        icon: L.divIcon({
          className:'route-distance-icon',
          html:`<div class="route-distance-label">📏 ${Math.round(km).toLocaleString('en-US')} كم</div>`,
          iconSize:[0,0]
        }),
        interactive:false, zIndexOffset:500
      }));
    }
    // overall total distance badge, floated above the route's northernmost point
    const northmost = tripCities.reduce((m,c)=> c.lat>m.lat ? c : m, tripCities[0]);
    layers.push(L.marker([northmost.lat, northmost.lng], {
      icon: L.divIcon({
        className:'route-total-icon',
        html:`<div class="route-total-label">🧳 إجمالي المسافة الجوية: ${Math.round(totalKm).toLocaleString('en-US')} كم</div>`,
        iconSize:[0,0]
      }),
      interactive:false, zIndexOffset:600
    }));
  } else if(tripCities.length === 1){
    layers.push(L.circleMarker([tripCities[0].lat, tripCities[0].lng], { radius:7, weight:2, color:'#fff', fillColor:'#E63946', fillOpacity:1 }));
    layers.push(L.marker([tripCities[0].lat, tripCities[0].lng], {
      icon: L.divIcon({
        className:'route-city-name-icon',
        html:`<div class="route-city-name-label">📍 ${tripCities[0].name}</div>`,
        iconSize:[0,0]
      }),
      interactive:false, zIndexOffset:550
    }));
  }
  tripRouteLine = L.layerGroup(layers);
}

// Explicit action: the ONLY place that actually moves/updates the visible map for the trip.
function revealTripRoute(){
  if(tripCities.length < 1) return;
  updateTripRouteLine();
  if(tripRouteLine) tripRouteLine.addTo(overviewMap);
  closeTripModal();
  const mapEl = document.getElementById('map-overview');
  if(mapEl) mapEl.scrollIntoView({ behavior:'smooth', block:'center' });
  setTimeout(()=>{
    if(tripCities.length >= 2){
      const latlngs = tripCities.map(c=>[c.lat, c.lng]);
      overviewMap.flyToBounds(latlngs, { padding:[60,60], duration:0.9, maxZoom:6 });
    } else {
      overviewMap.flyTo([tripCities[0].lat, tripCities[0].lng], 5, { duration:0.8 });
    }
  }, 350);
  showTripToast('✅ تم رسم خط سير رحلتك على الخريطة!');
}

