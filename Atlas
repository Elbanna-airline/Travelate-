// ---------- Hotels Modal Functions ----------
function openHotelsModal(cityName, flag, country){
  const list = document.getElementById('hotels-list');
  const cityHeader = document.getElementById('hotels-city-name');
  const cityFlag = document.getElementById('hotels-city-flag');
  const cityCount = document.getElementById('hotels-city-count');

  cityHeader.textContent = 'فنادق ' + cityName;
  cityFlag.textContent = flag || '🏨';

  const hotels = HOTELS_DATA[cityName];
  if(!hotels || hotels.length === 0){
    list.innerHTML = '<p class="hotels-empty">لا توجد بيانات فنادق متوفرة لهذه المدينة حاليًا.</p>';
    cityCount.textContent = '';
  } else {
    cityCount.textContent = hotels.length + ' فندق / فنادق';
    list.innerHTML = hotels.map((h, i) => {
      // Extract price indicator from description
      let priceTag = '';
      const desc = h.desc || '';
      if(desc.includes('اقتصادي')) priceTag = '<span class="hotel-price-tag">💰 اقتصادي</span>';
      else if(desc.includes('جيد') && !desc.includes('متوسط')) priceTag = '<span class="hotel-price-tag">💰💰 سعر جيد</span>';
      else if(desc.includes('متوسط')) priceTag = '<span class="hotel-price-tag">💰💰💰 متوسط</span>';
      else if(desc.includes('مرتفع')) priceTag = '<span class="hotel-price-tag">💰💰💰💰 مرتفع</span>';
      else priceTag = '<span class="hotel-price-tag">🏨 فندق موصى به</span>';

      return `<div class="hotel-item">
        <div class="hotel-name">${i+1}. ${h.name}</div>
        <div class="hotel-desc">${h.desc}</div>
        ${priceTag}
      </div>`;
    }).join('');
  }

  const overlay = document.getElementById('hotels-overlay');
  overlay.style.display = 'flex';
  void overlay.offsetWidth;
  overlay.classList.add('show');
}

function closeHotelsModal(){
  const overlay = document.getElementById('hotels-overlay');
  overlay.classList.remove('show');
  const onEnd = function(e){
    if(e.target !== overlay) return;
    overlay.style.display = 'none';
    overlay.removeEventListener('transitionend', onEnd);
  };
  overlay.addEventListener('transitionend', onEnd);
}

// Close hotels modal with Escape key
document.addEventListener('keydown', function(e){
  if(e.key === 'Escape'){
    closeHotelsModal();
  }
});

