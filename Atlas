    --primary-light:#14B8A6;

    /* legacy tokens kept for compatibility, remapped to the new palette */
    --parchment:#FFFFFF;
    --parchment-2:#F1F5F9;
    --brass:#0F6E63;
    --brass-light:#14B8A6;
    --teal:#0F6E63;
    --rust:#B14A34;
    --ice:#4A7FA5;
    --plum:#7B3F61;
    --cream:#1E293B;

    /* soft layered shadows */
    --shadow-sm:0 1px 2px rgba(15,23,42,.05), 0 1px 3px rgba(15,23,42,.06);
    --shadow-md:0 4px 10px rgba(15,23,42,.06), 0 10px 24px -8px rgba(15,23,42,.10);
    --shadow-lg:0 12px 28px -8px rgba(15,23,42,.14), 0 4px 12px rgba(15,23,42,.06);
  }

  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:
      radial-gradient(circle at 12% 0%, rgba(15,110,99,.05) 0%, transparent 45%),
      radial-gradient(circle at 92% 8%, rgba(15,110,99,.04) 0%, transparent 40%),
      var(--bg);
    color:var(--ink);
    font-family:'Tajawal','Inter',sans-serif;
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
  }

  h1,h2,h3,.display{
    font-family:'Cairo','Inter',sans-serif;
    font-weight:800;
    line-height:1.3;
  }

  p, .body-text{ font-weight:400; line-height:1.6; }

  .mono{ font-family:'IBM Plex Mono','Inter',monospace; letter-spacing:.02em; }

  a{ color:inherit; }

  /* ---------- HERO ---------- */
  .hero{
    max-width:1180px;
    margin:0 auto;
    padding:88px 32px 48px;
    text-align:center;
    position:relative;
  }
  .hero .eyebrow{
    font-family:'IBM Plex Mono', monospace;
    letter-spacing:.35em;
    font-size:12px;
    color:var(--primary);
    text-transform:uppercase;
    margin-bottom:24px;
  }
  .hero .eyebrow::before,.hero .eyebrow::after{
    content:"✈";
    margin:0 14px;
    opacity:.6;
  }
  .hero h1{
    font-size:clamp(38px,6vw,64px);
    font-weight:800;
    margin:0 0 20px;
    color:var(--ink);
    letter-spacing:-.01em;
  }
  .hero p.sub{
    max-width:640px;
    margin:0 auto;
    color:var(--muted);
    font-size:17px;
    line-height:1.6;
  }
  .hero .stats{
    display:flex;
    justify-content:center;
    gap:14px;
    flex-wrap:wrap;
    margin-top:44px;
  }
  .stat-chip{
    border:1px solid var(--border);
    background:var(--surface);
    border-radius:999px;
    padding:10px 20px;
    font-size:13px;
    color:var(--ink-3);
    display:flex;
    gap:8px;
    align-items:center;
    box-shadow:var(--shadow-sm);
  }
  .stat-chip b{ color:var(--primary); font-family:'IBM Plex Mono',monospace; }

  /* ---------- OVERVIEW MAP ---------- */
  .overview-wrap{
    max-width:1180px;
    margin:36px auto 10px;
    padding:0 32px;
  }
  #map-overview{
    height:520px;
    border-radius:20px;
    border:1px solid var(--border);
    box-shadow:var(--shadow-lg);
  }
  .legend{
    display:flex;
    flex-wrap:wrap;
    gap:20px;
    justify-content:center;
    margin:24px 0 8px;
    font-size:13px;
    color:var(--muted);
  }
  .legend span{
    display:inline-flex; align-items:center; gap:8px;
  }
  .dot{ width:11px; height:11px; border-radius:50%; display:inline-block; box-shadow:0 0 0 3px rgba(15,23,42,.05);}

  /* ---------- NAV ---------- */
  nav.region-nav{
    position:sticky; top:0; z-index:40;
    backdrop-filter:blur(14px);
    background:rgba(248,250,252,.85);
    border-bottom:1px solid var(--border-soft);
    margin-top:44px;
  }
  .region-nav ul{
    max-width:1180px; margin:0 auto; padding:0 32px;
    list-style:none; display:flex; gap:6px; overflow-x:auto;
    scrollbar-width:none; position:relative;
  }
  .region-nav ul::-webkit-scrollbar{ display:none; }
  .region-nav a{
    display:block; white-space:nowrap;
    padding:16px 18px; font-size:14px; font-weight:600;
    color:var(--muted); text-decoration:none;
    border-bottom:2px solid transparent;
    transition:color .3s cubic-bezier(0.4,0,0.2,1);
  }
  .region-nav a:hover{ color:var(--ink); }
  .region-nav a.active{ color:var(--primary); }
  .nav-indicator{
    position:absolute; bottom:0; height:2px; background:var(--primary);
    border-radius:2px;
    transition:left .4s cubic-bezier(0.65,0,0.35,1), width .4s cubic-bezier(0.65,0,0.35,1), opacity .25s ease;
    opacity:0; pointer-events:none;
  }
  .nav-indicator.ready{ opacity:1; }

  /* ---------- REGION SECTIONS ---------- */
  section.region{
    max-width:1180px;
    margin:0 auto;
    padding:72px 32px 24px;
    scroll-margin-top:70px;
  }
  .region-head{
    display:flex; align-items:baseline; gap:16px; margin-bottom:8px; flex-wrap:wrap;
  }
  .region-head .num{
    font-family:'IBM Plex Mono',monospace;
    color:var(--accent, var(--primary));
    font-size:14px; opacity:.85;
  }
  .region-head h2{
    font-size:clamp(26px,3.4vw,36px);
    margin:0;
    font-weight:800;
    color:var(--ink);
  }
  .region-intro{
    color:var(--muted); max-width:760px; margin:12px 0 32px; font-size:15.5px; line-height:1.6;
  }

  /* ---------- COUNTRY QUICK-NAV (chips under region intro) ---------- */
  .country-quicknav{
    display:flex; flex-wrap:wrap; gap:8px;
    margin:0 0 42px;
  }
  .country-quicknav a{
    display:inline-flex; align-items:center; gap:7px;
    text-decoration:none;
    font-size:13px; font-weight:600;
    color:var(--ink-3);
    background:var(--surface);
    border:1px solid var(--border);
    padding:7px 14px 7px 10px;
    border-radius:999px;
    box-shadow:var(--shadow-sm);
    transition:background .2s ease, border-color .2s ease, transform .2s ease;
  }
  .country-quicknav a:hover{
    background:var(--bg-2);
    border-color:var(--accent, var(--primary));
    transform:translateY(-1px);
  }
  .country-quicknav a .cnt{
    font-family:'IBM Plex Mono',monospace; font-size:10.5px;
    color:var(--muted-2);
  }

  /* ---------- COUNTRY BLOCK ---------- */
  .country-block{
    margin-bottom:60px;
    padding-top:6px;
    scroll-margin-top:78px;
  }
  .country-block:last-child{ margin-bottom:16px; }
  .country-head{
    display:flex; align-items:center; gap:14px;
    margin-bottom:20px;
  }
  .country-head .flag-badge{
    width:46px; height:46px; flex-shrink:0;
    border-radius:50%;
    background:var(--accent, var(--primary));
    display:flex; align-items:center; justify-content:center;
    font-size:22px;
    box-shadow:var(--shadow-md);
  }
  .country-head h3{
    margin:0; font-size:clamp(19px,2.3vw,24px); font-weight:700;
    color:var(--ink);
  }
  .country-head .count-chip{
    font-family:'IBM Plex Mono',monospace; font-size:11.5px;
    color:var(--muted); background:var(--surface);
    border:1px solid var(--border);
    padding:4px 10px; border-radius:999px; white-space:nowrap;
  }
  .country-head .head-line{
    flex:1; height:1px;
    background:linear-gradient(90deg, var(--divider), transparent);
  }

  .country-map{
    height:260px;
    border-radius:16px;
    border:1px solid var(--border);
    margin-bottom:24px;
    box-shadow:var(--shadow-md);
  }

  /* ---------- CARD GRID ---------- */
  .grid{
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(290px,1fr));
    gap:22px;
    margin-bottom:12px;
  }

  /* ---------- TICKET CARD ---------- */
  .ticket{
    position:relative;
    display:flex;
    background:var(--surface);
    color:var(--ink-text);
    border-radius:16px;
    overflow:hidden;
    border:1px solid var(--border);
    box-shadow:var(--shadow-md);
    transition:transform .35s cubic-bezier(0.16,1,0.3,1), box-shadow .35s cubic-bezier(0.16,1,0.3,1);
  }
  .ticket:hover{ transform:translateY(-4px); box-shadow:var(--shadow-lg); }

  .ticket .stub{
    width:56px;
    flex-shrink:0;
    background:var(--accent, var(--primary));
    color:#fff;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    gap:10px;
    padding:16px 0;
    position:relative;
  }
  .ticket .stub .flag{ font-size:22px; }
  .ticket .stub .country{
    writing-mode:vertical-rl;
    text-orientation:mixed;
    font-size:12.5px;
    font-weight:600;
    letter-spacing:.05em;
  }

  .ticket .divider{
    width:0;
    border-right:2px dashed rgba(15,23,42,.15);
    position:relative;
  }
  .ticket .divider::before,.ticket .divider::after{
    content:"";
    position:absolute;
    width:18px; height:18px;
    background:var(--bg);
    border-radius:50%;
    right:-9px;
  }
  .ticket .divider::before{ top:-9px; }
  .ticket .divider::after{ bottom:-9px; }

  .ticket .body{
    padding:20px 22px 18px;
    display:flex;
    flex-direction:column;
    gap:9px;
    flex:1;
  }
  .ticket .body h3{
    margin:0; font-size:20px; font-weight:700; color:var(--ink);
  }
  .ticket .body p.desc{
    margin:0; font-size:13.8px; line-height:1.6; color:var(--ink-3); flex:1;
  }
  .ticket .meta{
    display:flex; justify-content:space-between; align-items:center;
    margin-top:6px; gap:10px; flex-wrap:wrap;
  }
  .ticket .coords{
    font-size:11px; color:var(--muted-2);
  }
  .ticket .gmap-btn{
    display:inline-flex; align-items:center; gap:6px;
    font-size:12.5px; font-weight:600;
    text-decoration:none;
    color:#fff;
    background:var(--accent, var(--primary));
    padding:7px 14px;
    border-radius:999px;
    white-space:nowrap;
    transition:filter .2s ease;
  }
  .ticket .gmap-btn:hover{ filter:brightness(1.12); }

  /* ---------- EXPANDABLE TICKET DETAILS (why to visit / must-do / landmarks) ---------- */
  .ticket .details-toggle{
    display:inline-flex; align-items:center; gap:5px;
    font-size:12px; font-weight:600;
    color:var(--accent, var(--primary));
    background:none; border:none; cursor:pointer;
    padding:6px 2px; margin-top:2px;
    width:fit-content;
  }
  .ticket .details-toggle .chev{ transition:transform .25s ease; display:inline-block; }
  .ticket.expanded .details-toggle .chev{ transform:rotate(180deg); }
  .ticket .details-panel{
    max-height:0; overflow:hidden;
    transition:max-height .3s ease, opacity .25s ease, margin-top .3s ease;
    opacity:0;
  }
  .ticket.expanded .details-panel{
    max-height:600px; opacity:1; margin-top:6px;
  }
  .ticket .details-panel .why-row, .ticket .details-panel .mustdo-row{
    display:flex; gap:8px; font-size:12.8px; line-height:1.6;
    color:var(--ink-3); margin-bottom:9px;
  }
  .ticket .details-panel .row-icon{ flex-shrink:0; }
  .ticket .details-panel .landmarks-title{
    font-size:11.5px; font-weight:700; color:var(--muted);
    margin:9px 0 7px;
  }
  .ticket .details-panel .landmarks-list{
    display:flex; flex-wrap:wrap; gap:6px; margin:0 0 4px; padding:0; list-style:none;
  }
  .ticket .details-panel .landmarks-list li{
    font-size:11.5px; color:var(--ink-text);
    background:var(--bg-2);
    border:1px solid var(--border);
    padding:4px 10px; border-radius:999px;
  }

  /* ---------- FOOTER ---------- */
  footer{
    max-width:1180px; margin:64px auto 0; padding:32px 32px 64px;
    color:var(--muted-2); font-size:13px; text-align:center;
    border-top:1px solid var(--border-soft);
  }

  /* Leaflet popup styling */
  .leaflet-popup-content-wrapper{
    background:var(--surface); color:var(--ink-text); border-radius:12px;
    font-family:'Tajawal',sans-serif;
    box-shadow:var(--shadow-lg);
  }
  .leaflet-popup-content{ margin:14px 16px; font-size:13.5px; line-height:1.6; }
  .leaflet-popup-content b{ font-family:'Cairo',serif; font-size:15px; }
  .leaflet-popup-tip{ background:var(--surface); }
  .popup-link{
    display:inline-block; margin-top:6px; font-size:12px; font-weight:600;
    color:var(--primary); text-decoration:none;
  }

  @media (max-width:560px){
    .hero{ padding:56px 20px 30px; }
    .overview-wrap, section.region{ padding-left:20px; padding-right:20px; }
    #map-overview{ height:380px; }
  }

  /* ---------- ADD-TO-TRIP BUTTON ---------- */
  .ticket{ cursor:pointer; }
  .ticket .add-trip-btn{
    display:inline-flex; align-items:center; gap:5px;
    font-size:12px; font-weight:600;
    border:1.5px solid var(--accent,var(--primary));
    color:var(--accent,var(--primary));
    background:var(--surface);
    padding:6px 12px; border-radius:999px;
    cursor:pointer; white-space:nowrap;
    transition:background .3s cubic-bezier(0.4,0,0.2,1), color .3s cubic-bezier(0.4,0,0.2,1), transform .3s cubic-bezier(0.4,0,0.2,1);
  }
  .ticket .add-trip-btn:hover{ background:var(--accent,var(--primary)); color:#fff; transform:translateY(-1px); }
  .ticket.in-trip{ outline:3px solid var(--primary-light); outline-offset:2px; }
  .ticket.in-trip .add-trip-btn{
    background:var(--accent,var(--primary)); color:#fff;
  }

  /* ---------- TRIP FAB ---------- */
  #trip-fab{
    position:fixed; z-index:900; left:22px; bottom:22px;
    background:var(--primary);
    color:#fff; border:none; border-radius:999px;
    padding:14px 22px; font-family:'Tajawal',sans-serif; font-weight:700; font-size:14.5px;
    box-shadow:var(--shadow-lg);
    display:none; align-items:center; gap:10px; cursor:pointer;
    transition:transform .3s cubic-bezier(0.4,0,0.2,1), box-shadow .3s cubic-bezier(0.4,0,0.2,1), filter .3s cubic-bezier(0.4,0,0.2,1);
  }
  #trip-fab.show{ display:flex; }
  #trip-fab:hover{ transform:translateY(-2px); filter:brightness(1.08); }
  #trip-fab .count{
    background:rgba(255,255,255,.2); color:#fff;
    border-radius:50%; width:24px; height:24px;
    display:flex; align-items:center; justify-content:center;
    font-family:'IBM Plex Mono',monospace; font-size:13px;
  }

  /* ---------- TRIP MODAL ---------- */
  #trip-overlay{
    position:fixed; inset:0; background:rgba(15,23,42,0);
    z-index:950; display:none; align-items:flex-end; justify-content:center;
    backdrop-filter:blur(0px); -webkit-backdrop-filter:blur(0px);
    transition:background .35s cubic-bezier(0.4,0,0.2,1), backdrop-filter .35s cubic-bezier(0.4,0,0.2,1);
  }
  #trip-overlay.show{
    display:flex;
    background:rgba(15,23,42,.45);
    backdrop-filter:blur(6px); -webkit-backdrop-filter:blur(6px);
  }
  #trip-modal{
    background:var(--surface); color:var(--ink);
    width:100%; max-width:760px; max-height:88vh; overflow-y:auto;
    border-radius:24px 24px 0 0; padding:28px 28px 36px;
    border:1px solid var(--border);
    box-shadow:var(--shadow-lg);
    opacity:0; transform:translateY(40px) scale(.98);
    transition:opacity .38s cubic-bezier(0.16,1,0.3,1), transform .38s cubic-bezier(0.16,1,0.3,1);
  }
  #trip-overlay.show #trip-modal{
    opacity:1; transform:translateY(0) scale(1);
  }
  @media (min-width:820px){
    #trip-overlay{ align-items:center; }
    #trip-modal{ border-radius:24px; max-height:82vh; }
  }
  #trip-modal h3{ margin:0 0 6px; font-size:22px; color:var(--ink); }
  #trip-modal .trip-sub{ color:var(--muted); font-size:13.5px; margin:0 0 22px; line-height:1.6; }
  #trip-close{
    position:sticky; float:left; top:0; background:none; border:none;
    color:var(--muted); font-size:22px; cursor:pointer; line-height:1;
  }
  #trip-list{ display:flex; flex-direction:column; gap:10px; margin-bottom:24px; }
  .trip-item{
    display:flex; align-items:center; gap:12px;
    background:var(--bg-2); border-radius:14px; padding:12px 16px;
    border:1px solid var(--border);
  }
  .trip-item .order{
    font-family:'IBM Plex Mono',monospace; color:var(--primary);
    width:22px; text-align:center; font-size:13px;
  }
  .trip-item .flag{ font-size:18px; }
  .trip-item .info{ flex:1; }
  .trip-item .info .city{ font-weight:700; font-size:14.5px; color:var(--ink); }
  .trip-item .info .country{ font-size:12px; color:var(--muted); }
  .trip-item .move-btns{ display:flex; gap:4px; }
  .trip-item button.icon-btn{
    background:var(--surface); border:1px solid var(--border);
    color:var(--ink-3); border-radius:8px; width:28px; height:28px;
    cursor:pointer; font-size:13px; display:flex; align-items:center; justify-content:center;
  }
  .trip-item button.icon-btn:hover{ background:var(--bg); }
  .trip-item button.remove-btn{ color:#C0503C; }

  #trip-calc-btn{
    display:block; width:100%; border:none; border-radius:14px;
    background:var(--primary);
    color:#fff; font-weight:800; font-size:15px; padding:15px;
    cursor:pointer; margin-bottom:24px;
    box-shadow:var(--shadow-sm);
  }
  #trip-calc-btn:disabled{ opacity:.4; cursor:not-allowed; }

  #trip-results{ display:flex; flex-direction:column; gap:16px; }
  .leg-card{
    background:var(--bg-2); border-radius:16px; padding:18px 20px;
    border:1px solid var(--border);
  }
  .leg-card .leg-route{
    font-weight:700; font-size:15px; margin-bottom:5px; color:var(--ink);
    display:flex; align-items:center; gap:8px; flex-wrap:wrap;
  }
  .leg-card .leg-route .arrow{ color:var(--primary); }
  .leg-card .leg-dist{
    font-family:'IBM Plex Mono',monospace; font-size:12.5px; color:var(--muted); margin-bottom:14px;
  }
  .leg-card .leg-actions{ display:flex; gap:10px; flex-wrap:wrap; }
  .leg-btn{
    display:inline-flex; align-items:center; gap:6px;
    text-decoration:none; font-size:12.5px; font-weight:600;
    padding:8px 14px; border-radius:999px; white-space:nowrap;
  }
  .leg-btn.car{ background:#2F7256; color:#fff; }
  .leg-btn.compare{ background:#2E6486; color:#fff; }
  .leg-btn:hover{ filter:brightness(1.12); }
  .trip-total{
    text-align:center; font-size:13px; color:var(--muted); margin-top:8px;
  }
  .trip-empty{ color:var(--muted); font-size:14px; text-align:center; padding:24px 0; line-height:1.6; }

  /* ---------- ON-MAP DISTANCE LABEL (shown on the red trip route line) ---------- */
  .route-distance-label{
    display:inline-flex; align-items:center; gap:5px;
    background:var(--ink); color:#fff;
    font-family:'IBM Plex Mono',monospace; font-weight:700; font-size:11.5px;
    padding:4px 10px; border-radius:999px; white-space:nowrap;
    border:1.5px solid var(--primary-light);
    box-shadow:var(--shadow-sm);
    transform:translate(-50%,-50%);
  }
  .route-total-label{
    display:inline-flex; align-items:center; gap:6px;
    background:var(--primary);
    color:#fff; font-family:'IBM Plex Mono',monospace; font-weight:800; font-size:12.5px;
    padding:6px 14px; border-radius:999px; white-space:nowrap;
    box-shadow:var(--shadow-md);
    transform:translate(-50%,-100%);
    margin-top:-14px;
  }
  .route-city-name-label{
    display:inline-flex; align-items:center; gap:4px;
    background:#C0503C; color:#fff;
    font-family:'Tajawal',sans-serif; font-weight:800; font-size:12px;
    padding:3px 10px; border-radius:999px; white-space:nowrap;
    border:1.5px solid #fff;
    box-shadow:var(--shadow-sm);
    transform:translate(-50%,-140%);
  }
  .trip-note{
    font-size:11.5px; color:var(--muted-2); margin-top:18px; line-height:1.6;
    border-top:1px dashed var(--border); padding-top:14px;
  }

  /* ---------- SHOW-ROUTE BUTTON (explicit action, doesn't auto-fly the map) ---------- */
  #trip-show-route-btn{
    width:100%; margin-top:12px;
    background:var(--primary-light);
    color:#fff; border:none; border-radius:14px;
    padding:13px 18px; font-family:'Tajawal',sans-serif; font-weight:700; font-size:14px;
    cursor:pointer; transition:filter .3s cubic-bezier(0.4,0,0.2,1), transform .3s cubic-bezier(0.4,0,0.2,1);
  }
  #trip-show-route-btn:hover{ filter:brightness(1.06); transform:translateY(-1px); }
  #trip-show-route-btn:disabled{ opacity:.45; cursor:default; transform:none; }

  /* ---------- TRIP CONFIRMATION TOAST ---------- */
  .trip-toast{
    position:fixed; z-index:1200; left:50%; top:26px;
    transform:translateX(-50%) translateY(-24px);
    background:var(--ink); color:#fff;
    padding:13px 24px; border-radius:999px; font-weight:700; font-size:13.5px;
    box-shadow:var(--shadow-lg);
    opacity:0; pointer-events:none;
    transition:opacity .3s ease, transform .3s ease;
    display:flex; align-items:center; gap:8px;
  }
  .trip-toast.show{ opacity:1; transform:translateX(-50%) translateY(0); }

  /* ---------- NEAREST-CITY SUGGESTION POPUP ---------- */
  .nearest-suggestion{
    position:fixed; z-index:950; left:50%; bottom:22px;
    transform:translateX(-50%) translateY(24px);
    width:min(430px, 92vw);
    background:var(--surface); color:var(--ink-text);
    border-radius:20px; padding:20px 22px;
    box-shadow:var(--shadow-lg);
    border:1px solid var(--border);
    opacity:0; pointer-events:none;
    transition:opacity .25s ease, transform .25s ease;
  }
  .nearest-suggestion.show{ opacity:1; transform:translateX(-50%) translateY(0); pointer-events:auto; }
  .nearest-suggestion .ns-head{
    display:flex; justify-content:space-between; align-items:flex-start;
    margin-bottom:12px; gap:10px;
  }
  .nearest-suggestion .ns-title{ font-weight:700; font-size:14px; line-height:1.5; color:var(--ink); }
  .nearest-suggestion .ns-title b{ color:var(--primary); }
  .nearest-suggestion .ns-close{
    background:none; border:none; font-size:19px; cursor:pointer;
    color:var(--muted-2); line-height:1; flex-shrink:0; padding:2px;
  }
  .nearest-suggestion .ns-row{
    display:flex; justify-content:space-between; align-items:center; gap:10px;
    padding:10px 0; border-top:1px solid var(--border-soft);
  }
  .nearest-suggestion .ns-row:first-of-type{ border-top:none; }
  .nearest-suggestion .ns-info{ min-width:0; }
  .nearest-suggestion .ns-label{ font-size:11px; color:var(--muted); margin-bottom:2px; }
  .nearest-suggestion .ns-city{ font-weight:700; font-size:13.5px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; color:var(--ink); }
  .nearest-suggestion .ns-km{ font-size:11px; color:var(--muted); font-family:'IBM Plex Mono',monospace; margin-top:1px; }
  .nearest-suggestion .ns-add{
    font-size:12px; font-weight:700; background:var(--primary); color:#fff;
    border:none; padding:7px 14px; border-radius:999px; cursor:pointer; white-space:nowrap;
    transition:filter .2s ease;
  }
  .nearest-suggestion .ns-add:hover{ filter:brightness(1.1); }
  .nearest-suggestion .ns-add:disabled{ opacity:.5; cursor:default; }

  /* ---------- HOTELS BUTTON ---------- */
  .ticket .hotels-btn{
    display:inline-flex; align-items:center; gap:5px;
    font-size:12px; font-weight:600;
    border:1.5px solid var(--accent,var(--primary));
    color:var(--accent,var(--primary));
    background:var(--surface);
    padding:6px 12px; border-radius:999px;
    cursor:pointer; white-space:nowrap;
    transition:background .3s cubic-bezier(0.4,0,0.2,1), color .3s cubic-bezier(0.4,0,0.2,1), transform .3s cubic-bezier(0.4,0,0.2,1);
  }
  .ticket .hotels-btn:hover{ background:var(--accent,var(--primary)); color:#fff; transform:translateY(-1px); }

  /* ---------- HOTELS MODAL ---------- */
  #hotels-overlay{
    position:fixed; inset:0; background:rgba(15,23,42,0);
    z-index:960; display:none; align-items:flex-end; justify-content:center;
    backdrop-filter:blur(0px); -webkit-backdrop-filter:blur(0px);
    transition:background .35s cubic-bezier(0.4,0,0.2,1), backdrop-filter .35s cubic-bezier(0.4,0,0.2,1);
  }
  #hotels-overlay.show{
    display:flex;
    background:rgba(15,23,42,.45);
    backdrop-filter:blur(6px); -webkit-backdrop-filter:blur(6px);
  }
  #hotels-modal{
    background:var(--surface); color:var(--ink);
    width:100%; max-width:720px; max-height:85vh; overflow-y:auto;
    border-radius:24px 24px 0 0; padding:28px 28px 36px;
    border:1px solid var(--border);
    box-shadow:var(--shadow-lg);
    opacity:0; transform:translateY(40px) scale(.98);
    transition:opacity .38s cubic-bezier(0.16,1,0.3,1), transform .38s cubic-bezier(0.16,1,0.3,1);
  }
  #hotels-overlay.show #hotels-modal{
    opacity:1; transform:translateY(0) scale(1);
  }
  @media (min-width:820px){
    #hotels-overlay{ align-items:center; }
    #hotels-modal{ border-radius:24px; max-height:82vh; }
  }
  #hotels-modal h3{ margin:0 0 6px; font-size:22px; color:var(--ink); }
  #hotels-modal .hotels-sub{ color:var(--muted); font-size:13.5px; margin:0 0 22px; line-height:1.6; }
  #hotels-close{
    position:sticky; float:left; top:0; background:none; border:none;
    color:var(--muted); font-size:22px; cursor:pointer; line-height:1;
  }
  #hotels-list{ display:flex; flex-direction:column; gap:10px; margin-bottom:8px; }
  .hotel-item{
    display:flex; flex-direction:column; gap:6px;
    background:var(--bg-2); border-radius:14px; padding:14px 18px;
    border:1px solid var(--border);
    transition:transform .2s ease, box-shadow .2s ease;
  }
  .hotel-item:hover{ transform:translateY(-1px); box-shadow:var(--shadow-sm); }
  .hotel-item .hotel-name{ font-weight:700; font-size:14.5px; color:var(--ink); }
  .hotel-item .hotel-desc{ font-size:12.8px; color:var(--ink-3); line-height:1.6; }
  .hotel-item .hotel-price-tag{
    display:inline-flex; align-items:center; gap:4px;
    font-size:11px; font-weight:600; color:var(--primary);
    background:rgba(15,110,99,.08); padding:3px 10px; border-radius:999px;
    width:fit-content; margin-top:2px;
  }
  .hotels-empty{ color:var(--muted); font-size:14px; text-align:center; padding:24px 0; line-height:1.6; }
  .hotels-city-header{
    display:flex; align-items:center; gap:10px;
    margin-bottom:18px; padding-bottom:14px;
    border-bottom:2px solid var(--border);
  }
  .hotels-city-header .city-flag{ font-size:28px; }
  .hotels-city-header .city-info{ flex:1; }
  .hotels-city-header .city-name{ font-weight:800; font-size:18px; color:var(--ink); }
  .hotels-city-header .city-count{ font-size:12px; color:var(--muted); }

</style>
