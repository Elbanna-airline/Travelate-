// ---------- Nearest-city suggestions (shown right after adding a city to the trip) ----------
const ALL_CITIES = [];
REGIONS.forEach(region=>{
  region.countries.forEach(country=>{
    country.cities.forEach(city=>{
      ALL_CITIES.push({ name:city.name, en:city.en, lat:city.lat, lng:city.lng, flag:country.flag, country:country.name });
    });
  });
});

function findNearestCities(city){
  let nearestSame=null, bestSameKm=Infinity, nearestDiff=null, bestDiffKm=Infinity;
  ALL_CITIES.forEach(other=>{
    if(other.lat===city.lat && other.lng===city.lng) return;
    if(tripCities.some(t=> t.lat===other.lat && t.lng===other.lng)) return; // skip cities already in the plan
    const km = haversineKm(city.lat, city.lng, other.lat, other.lng);
    if(other.country === city.country){
      if(km < bestSameKm){ bestSameKm = km; nearestSame = other; }
    } else if(km < bestDiffKm){ bestDiffKm = km; nearestDiff = other; }
  });
  return { nearestSame, bestSameKm, nearestDiff, bestDiffKm };
}

function showNearestSuggestion(city){
  const { nearestSame, bestSameKm, nearestDiff, bestDiffKm } = findNearestCities(city);
  if(!nearestSame && !nearestDiff) return;
  const box = document.getElementById('nearest-suggestion');
  const rowHtml = (label, other, km)=> !other ? '' : `
    <div class="ns-row">
      <div class="ns-info">
        <div class="ns-label">${label}</div>
        <div class="ns-city">${other.flag} ${other.name}</div>
        <div class="ns-km">${Math.round(km).toLocaleString('en-US')} كم من ${city.name}</div>
      </div>
      <button class="ns-add" onclick='addSuggestedCity(${JSON.stringify(other)})'>➕ أضف</button>
    </div>`;
  box.innerHTML = `
    <div class="ns-head">
      <div class="ns-title">أقرب المدن لـ<b>${city.name}</b> على خط السير:</div>
      <button class="ns-close" onclick="closeNearestSuggestion()">×</button>
    </div>
    ${rowHtml('🏙️ أقرب مدينة (نفس الدولة)', nearestSame, bestSameKm)}
    ${rowHtml('🌍 أقرب مدينة (دولة تانية)', nearestDiff, bestDiffKm)}
  `;
  box.classList.add('show');
  clearTimeout(showNearestSuggestion._t);
  showNearestSuggestion._t = setTimeout(closeNearestSuggestion, 9000);
}

function closeNearestSuggestion(){
  document.getElementById('nearest-suggestion').classList.remove('show');
}

function addSuggestedCity(cityRef){
  if(tripCities.some(c=> c.lat===cityRef.lat && c.lng===cityRef.lng)) return;
  tripCities.push({ name:cityRef.name, en:cityRef.en, flag:cityRef.flag, country:cityRef.country, lat:cityRef.lat, lng:cityRef.lng });
  // keep the matching ticket card's UI in sync, if it's currently rendered
  document.querySelectorAll('.ticket').forEach(t=>{
    if(parseFloat(t.dataset.lat)===cityRef.lat && parseFloat(t.dataset.lng)===cityRef.lng){
      t.classList.add('in-trip');
      const btn = t.querySelector('.add-trip-btn');
      if(btn) btn.textContent = '✅ في المخطط';
    }
  });
  updateTripFab();
  renderTripList();
  closeNearestSuggestion();
  showNearestSuggestion(cityRef);
}

// ---------- Leaflet: per-country maps (lazy init on scroll) ----------
const countryMapInstances = {};
function initCountryMap(region, country, idx){
  const key = countryKey(region.id, idx);
  if(countryMapInstances[key]) return;
  const mapEl = document.getElementById(`map-${key}`);
  if(!mapEl) return;

  // frame the map around just this country's cities
  const bounds = country.cities.map(city=>[city.lat, city.lng]);
  const map = L.map(`map-${key}`, { scrollWheelZoom:false }).setView(region.center, region.zoom);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution:'&copy; OpenStreetMap contributors',
    maxZoom:18
  }).addTo(map);

  country.cities.forEach(city=>{
    const marker = L.circleMarker([city.lat, city.lng], {
      radius:8, weight:2, color:'#fff', fillColor:region.accent, fillOpacity:1
    }).addTo(map);
    marker.bindPopup(`<b>${country.flag} ${city.name}</b><br>${city.desc}<br><a class="popup-link" href="${gmapUrl(city.lat,city.lng)}" target="_blank" rel="noopener">فتح في خرائط جوجل ↗</a>`);
    cityMarkers[markerKey(key, city.lat, city.lng)] = marker;
  });
  if(bounds.length){ map.fitBounds(bounds, {padding:[28,28]}); }
  countryMapInstances[key] = map;
}

const observer = new IntersectionObserver((entries)=>{
  entries.forEach(entry=>{
    if(entry.isIntersecting){
      const found = findRegionAndCountry(entry.target.dataset.mapkey);
      if(found) initCountryMap(found.region, found.country, found.idx);
    }
  });
}, { rootMargin:'200px' });

document.querySelectorAll('.country-block').forEach(el=> observer.observe(el));

// init first country immediately (likely visible on load after scrolling a bit)
initCountryMap(REGIONS[0], REGIONS[0].countries[0], 0);

