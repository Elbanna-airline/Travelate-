# ============================================================
# بيئة التطوير والإنتاج - TravELate Authentication System
# ============================================================

# ============================================================
# JWT - JSON Web Token Configuration
# ============================================================
# استخدم مفتاح عشوائي قوي في production
# يمكنك إنشاء واحد باستخدام: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

JWT_EXPIRY=7d

# ============================================================
# Gemini API - Image Recognition (موجود بالفعل)
# ============================================================
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================
# قاعدة البيانات - Database Configuration
# ============================================================
# استخدم أحد الخيارات:
# - PostgreSQL: postgresql://user:password@localhost:5432/travelate
# - MongoDB: mongodb+srv://user:password@cluster.mongodb.net/travelate
# - Supabase: postgresql://postgres:password@db.supabasehost.com:5432/postgres

DATABASE_URL=postgresql://user:password@localhost:5432/travelate

# ============================================================
# SMTP - Email Configuration
# ============================================================
# Gmail + App Password مثال:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# استخدم App Password وليس كلمة المرور العادية إذا كان 2FA مفعّلاً
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@travelate.com
SMTP_FROM_NAME=TravELate

# بدائل: Mailgun, SendGrid, Brevo
# SMTP_PROVIDER=sendgrid
# SENDGRID_API_KEY=your-sendgrid-api-key

# ============================================================
# البيئة - Environment
# ============================================================
NODE_ENV=development
# development, staging, production

# ============================================================
# السيرفر - Server Configuration
# ============================================================
PORT=8888
HOST=localhost

# ============================================================
# CORS - Cross-Origin Resource Sharing
# ============================================================
CORS_ORIGIN=http://localhost:3000,https://travelate.com

# ============================================================
# الأمان - Security
# ============================================================
# Enable/Disable features
ENABLE_2FA=false
ENABLE_RATE_LIMITING=true
ENABLE_EMAIL_VERIFICATION=true

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Password requirements
MIN_PASSWORD_LENGTH=8
REQUIRE_UPPERCASE=true
REQUIRE_NUMBERS=true
REQUIRE_SPECIAL_CHARS=false

# Account lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME_MINUTES=30

# ============================================================
# توكنات - Token Expiry
# ============================================================
# Email verification token
EMAIL_VERIFICATION_EXPIRY=24h

# Password reset token
PASSWORD_RESET_EXPIRY=1h

# ============================================================
# Logging - السجلات
# ============================================================
LOG_LEVEL=debug
# debug, info, warn, error

# ============================================================
# خدمات خارجية - Third-party Services
# ============================================================
# Firebase (بديل لـ Supabase)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email@firebase.com

# Auth0 (بديل شامل)
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# Supabase (موصى به)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# أخرى - Miscellaneous
# ============================================================
# Sentry error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Google Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# App URL
APP_URL=https://travelate.com
API_URL=https://api.travelate.com
